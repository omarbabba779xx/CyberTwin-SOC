      "technique_id": "T1110.001",
      "technique_name": "Brute Force: Password Guessing",
      "tactic": "Credential Access",
      "target_host": "srv-rdp-01",
      "target_user": "administrator",
      "delay_seconds": 0,
      "stealth_level": "low",
      "indicators": {
        "source_ip": "91.193.18.42",
        "protocol": "RDP",
        "total_attempts": 800,
        "target_ip": "10.0.1.5"
      },
      "ioc": {
        "ips": ["91.193.18.42", "185.220.101.45"],
        "tools": ["Hydra", "Crowbar", "RDPBrute"]
      }
    },
    {
      "phase": 2,
      "name": "Credential Dumping — LSASS Memory",
      "description": "Attacker uses a renamed procdump64.exe to dump LSASS memory, then runs Mimikatz sekurlsa::logonpasswords to extract NTLM hashes and Kerberos tickets from memory.",
      "technique_id": "T1003.001",
      "technique_name": "OS Credential Dumping: LSASS Memory",
      "tactic": "Credential Access",
      "target_host": "srv-rdp-01",
      "target_user": "administrator",
      "delay_seconds": 180,
      "stealth_level": "medium",
      "indicators": {
        "tools": ["procdump64.exe", "mimikatz"],
        "commands": [
          "procdump64.exe -accepteula -ma lsass.exe C:\\Windows\\Temp\\lsass.dmp",
          "mimikatz.exe sekurlsa::logonpasswords",
          "mimikatz.exe lsadump::dcsync /domain:corp.local /user:krbtgt"
        ]
      },
      "ioc": {
        "file_hashes": {
          "mimikatz_sha256": "f6da9781ae5d55fa5a16b41a5b9f3a2a9c74d2e8f4c3b2a1f0e9d8c7b6a5f4e3"
        },
        "tools": ["mimikatz", "procdump"]
      }
    },
    {
      "phase": 3,
      "name": "DCSync — Domain Credential Theft",
      "description": "Using the Domain Admin account, the attacker performs a DCSync attack to replicate all domain credentials including the KRBTGT hash, enabling golden ticket attacks.",
