{
  "id": "sc-ransomware-001",
  "name": "BlackCat/ALPHV Ransomware-as-a-Service Attack",
  "description": "A full-chain BlackCat (ALPHV) RaaS attack: initial access via exposed RDP, credential dumping, lateral movement with PsExec, volume shadow copy deletion, NTDS.dit exfiltration for double extortion, and AES-256 file encryption across the domain. Modeled on real 2023-2024 BlackCat incidents against critical infrastructure.",
  "severity": "critical",
  "category": "ransomware",
  "threat_actor": {
    "name": "BlackCat/ALPHV",
    "aliases": ["ALPHV", "Noberus", "Sphynx"],
    "origin": "Russia/Eastern Europe",
    "motivation": "Financial extortion (double extortion RaaS)",
    "active_since": "2021"
  },
  "mitre_techniques_summary": [
    "T1190", "T1110.001", "T1078", "T1003.001", "T1003.006",
    "T1021.002", "T1490", "T1486", "T1048", "T1070.001", "T1562.001"
  ],
  "references": [
    "https://attack.mitre.org/software/S1068/",
    "https://www.cisa.gov/news-events/cybersecurity-advisories/aa23-353a",
    "https://www.mandiant.com/resources/blog/alphv-blackcat-ransomware"
  ],
  "kill_chain": ["initial_access", "execution", "persistence", "privilege_escalation", "defense_evasion", "credential_access", "lateral_movement", "collection", "exfiltration", "impact"],
  "phases": [
