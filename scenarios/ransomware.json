          "wmic /node:10.0.1.10 process call create 'cmd.exe /c ...'"
        ]
      },
      "ioc": {
        "tools": ["PsExec", "WMIC"]
      }
    },
    {
      "phase": 5,
      "name": "Defense Evasion — Disable Security Tools",
      "description": "Ransomware disables Windows Defender, Veeam backup services, and stops SQL/Exchange services to maximize encryption impact.",
      "technique_id": "T1562.001",
      "technique_name": "Impair Defenses: Disable or Modify Tools",
      "tactic": "Defense Evasion",
