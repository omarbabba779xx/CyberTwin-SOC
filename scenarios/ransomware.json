      "technique_name": "OS Credential Dumping: DCSync",
      "tactic": "Credential Access",
      "target_host": "srv-dc-01",
      "target_user": "administrator",
      "delay_seconds": 120,
      "stealth_level": "medium",
      "indicators": {
        "commands": [
          "mimikatz.exe lsadump::dcsync /domain:corp.local /all /csv",
          "secretsdump.py corp.local/administrator@10.0.1.2 -just-dc"
        ]
      },
      "ioc": {
        "tools": ["mimikatz", "secretsdump.py", "impacket"]
      }
    },
    {
      "phase": 4,
      "name": "Lateral Movement via PsExec and WMI",
      "description": "BlackCat spreads laterally across the domain using PsExec and WMIC with the stolen domain admin credentials, deploying the ransomware payload to every reachable host.",
