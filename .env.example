# =============================================================================
# CyberTwin SOC - Example environment file
# Copy this file to `.env` and replace EVERY placeholder before deployment.
# Setting ENV=production blocks startup if any default/weak value remains.
# =============================================================================

# ---- Runtime mode ----------------------------------------------------------
# Allowed values: development | production
ENV=development
DEBUG=false
APP_NAME=CyberTwin SOC
APP_VERSION=3.1.0

# ---- API server ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ---- CORS ------------------------------------------------------------------
# Vite dev server (5173) + nginx prod (port 80) + same-origin via reverse proxy.
# Comma-separated, NO wildcards in production.
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:80

# ---- JWT -------------------------------------------------------------------
# JWT_SECRET MUST be at least 64 characters in production.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE-WITH-AT-LEAST-64-RANDOM-CHARS-NOT-THIS-VALUE
JWT_ALGORITHM=HS256
# Access token lifetime (default 1h). Use POST /api/auth/refresh with the
# refresh_token from login to get a new access token without re-logging in.
JWT_EXPIRY_HOURS=1
REFRESH_EXPIRY_DAYS=7

# ---- Default user passwords -----------------------------------------------
# Each MUST be ≥ 12 chars and not in the known-default list.
# These accounts are created at startup with bcrypt-hashed passwords.
AUTH_ADMIN_PASSWORD=CHANGE-ME-strong-admin-password
AUTH_ANALYST_PASSWORD=CHANGE-ME-strong-analyst-password
AUTH_VIEWER_PASSWORD=CHANGE-ME-strong-viewer-password

# ---- Storage --------------------------------------------------------------
DB_PATH=data/cybertwin.db
# SQLite (demo/dev): set DATABASE_URL=sqlite:///./data/cybertwin.db
# PostgreSQL (production): set DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/cybertwin
# Then run: alembic upgrade head
DATABASE_URL=sqlite:///./data/cybertwin.db

# ---- Cache ----------------------------------------------------------------
# Leave empty to use in-memory cache. Set to enable Redis.
REDIS_URL=redis://localhost:6379

# ---- LLM (AI Analyst) -----------------------------------------------------
# Optional. If unreachable, the rule-based NLG fallback is used.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---- SOAR (TheHive + Cortex) ----------------------------------------------
# Used when running with --profile soar in docker-compose.
THEHIVE_URL=http://thehive:9000
THEHIVE_API_KEY=
THEHIVE_ORG=cybertwin
CORTEX_URL=http://cortex:9001
CORTEX_API_KEY=
